---
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;
---

<aside class={`stop-notice ${compact ? "stop-notice--compact" : ""}`} role="note">
  <div class="stop-notice__inner">
    <svg class="stop-notice__icon" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/>
      <line x1="10" y1="5" x2="10" y2="11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <circle cx="10" cy="14" r="1" fill="currentColor"/>
    </svg>
    <div class="stop-notice__text">
      <strong>Diese Praxis nimmt keine neuen Patienten auf.</strong>
      {!compact && (
        <p>
          Gewonnene Zeitfenster gehen ausnahmslos an akute Schmerzfälle.
          Warum das so ist und was sich ändern muß, erklärt diese Website.
        </p>
      )}
    </div>
  </div>
</aside>

<style>
  .stop-notice {
    background-color: var(--color-black);
    color: var(--color-white);
    padding: var(--space-4) var(--space-6);
    border-left: 4px solid var(--color-gold);
  }

  .stop-notice__inner {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    max-width: var(--max-width-text);
  }

  .stop-notice__icon {
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--color-gold);
  }

  .stop-notice__text strong {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-white);
    margin-bottom: var(--space-1);
  }

  .stop-notice__text p {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.6;
    max-width: none;
    margin: 0;
  }

  .stop-notice--compact {
    padding: var(--space-3) var(--space-4);
  }

  .stop-notice--compact .stop-notice__text strong {
    margin-bottom: 0;
    font-size: var(--text-base);
  }
</style>
