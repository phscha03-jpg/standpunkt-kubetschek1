---
const navLinks = [
  { href: "/hintergrund", label: "Hintergrund" },
  { href: "/standpunkt",  label: "Standpunkt"  },
  { href: "/mitmachen",   label: "Mitmachen"   },
  { href: "/kontakt",     label: "Kontakt"      },
];
const path = Astro.url.pathname;
---

<header class="nav-bar" role="banner">
  <div class="nav-bar__inner container">

    <!-- Logo-Block: Monogramm + Name auf zwei Zeilen -->
    <a href="/" class="nav-logo" aria-label="Startseite">
      <span class="nav-logo__initial" aria-hidden="true">RK</span>
      <span class="nav-logo__text">
        <span class="nav-logo__name">Dr. Roman Kubetschek</span>
        <span class="nav-logo__sub">Zahnarzt · Neubrandenburg · Standpunkt</span>
      </span>
    </a>

    <button class="nav-toggle" aria-expanded="false" aria-controls="nav-menu" aria-label="Navigation öffnen">
      <span></span><span></span>
    </button>

    <nav id="nav-menu" class="nav-links" aria-label="Hauptnavigation">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class={`nav-links__item ${path.startsWith(href) ? "is-active" : ""}`}
          aria-current={path.startsWith(href) ? "page" : undefined}
        >
          {label}
        </a>
      ))}
    </nav>

  </div>
  <!-- Fortschrittsbalken -->
  <div class="nav-progress" id="nav-progress" aria-hidden="true"></div>
</header>

<style>
  .nav-bar {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-black);
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .nav-bar__inner {
    display: flex;
    align-items: center;
    height: var(--nav-height);
    gap: var(--space-6);
  }

  /* Logo */
  .nav-logo {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
    flex-shrink: 0;
  }
  .nav-logo:focus-visible { outline: 2px solid var(--color-gold); outline-offset: 4px; }

  .nav-logo__initial {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background-color: var(--color-green);
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-white);
    letter-spacing: 0.04em;
    flex-shrink: 0;
  }

  .nav-logo__text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .nav-logo__name {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-white);
    letter-spacing: 0.01em;
  }

  .nav-logo__sub {
    font-size: 10px;
    font-weight: 400;
    color: rgba(255,255,255,0.4);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* Links */
  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-left: auto;
  }

  .nav-links__item {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    padding-block: var(--space-1);
    transition: color var(--transition-base);
  }
  .nav-links__item:hover { color: var(--color-white); }
  .nav-links__item.is-active { color: var(--color-gold); }

  /* Toggle */
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 6px;
    margin-left: auto;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-1);
  }
  .nav-toggle span {
    display: block;
    width: 22px;
    height: 1.5px;
    background-color: rgba(255,255,255,0.7);
    transition: opacity var(--transition-base);
  }

  /* Scroll-Fortschrittsbalken */
  .nav-progress {
    position: absolute;
    bottom: -1px;
    left: 0;
    height: 2px;
    width: 0%;
    background-color: var(--color-gold);
    transition: width 0.1s linear;
  }

  @media (max-width: 640px) {
    .nav-toggle { display: flex; }
    .nav-links {
      display: none;
      position: absolute;
      top: var(--nav-height);
      left: 0; right: 0;
      flex-direction: column;
      align-items: flex-start;
      background-color: var(--color-black);
      border-top: 1px solid rgba(255,255,255,0.08);
      padding: var(--space-3) var(--space-4);
      gap: var(--space-3);
    }
    .nav-links[data-open] { display: flex; }
    .nav-links__item { font-size: var(--text-sm); }
  }
</style>

<script>
  // Mobile Toggle
  const toggle = document.querySelector(".nav-toggle") as HTMLButtonElement;
  const menu   = document.getElementById("nav-menu");
  toggle?.addEventListener("click", () => {
    const open = menu?.hasAttribute("data-open");
    open ? menu?.removeAttribute("data-open") : menu?.setAttribute("data-open", "");
    toggle.setAttribute("aria-expanded", String(!open));
    toggle.setAttribute("aria-label", open ? "Navigation öffnen" : "Navigation schließen");
  });

  // Lese-Fortschrittsbalken
  const bar = document.getElementById("nav-progress");
  if (bar) {
    window.addEventListener("scroll", () => {
      const total = document.documentElement.scrollHeight - window.innerHeight;
      bar.style.width = total > 0 ? `${(window.scrollY / total) * 100}%` : "0%";
    }, { passive: true });
  }
</script>
