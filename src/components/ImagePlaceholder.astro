---
interface Props {
  filename: string;
  ratio: string;
  color?: string;
  alt: string;
  class?: string;
}

const {
  filename,
  ratio,
  color = "#2D5A42",
  alt,
  class: className = "",
} = Astro.props;

const [w, h] = ratio.split(":").map(Number);
const paddingBottom = `${((h / w) * 100).toFixed(4)}%`;
---

<figure class={`placeholder ${className}`} aria-label={alt}>
  <div class="placeholder__frame" style={`padding-bottom: ${paddingBottom};`}>
    <svg
      class="placeholder__svg"
      xmlns="http://www.w3.org/2000/svg"
      role="img"
      aria-label={alt}
    >
      <rect width="100%" height="100%" fill={color} />
      <text
        x="50%"
        y="45%"
        text-anchor="middle"
        dominant-baseline="middle"
        fill="rgba(255,255,255,0.5)"
        font-family="monospace"
        font-size="13"
      >{filename}</text>
      <text
        x="50%"
        y="60%"
        text-anchor="middle"
        dominant-baseline="middle"
        fill="rgba(255,255,255,0.3)"
        font-family="monospace"
        font-size="11"
      >{ratio}</text>
    </svg>
  </div>
  {alt && <figcaption class="visually-hidden">{alt}</figcaption>}
</figure>

<style>
  .placeholder { margin: 0; }

  .placeholder__frame {
    position: relative;
    width: 100%;
    height: 0;
    overflow: hidden;
  }

  .placeholder__svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
</style>
