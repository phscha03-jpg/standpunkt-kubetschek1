---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__body">

    <div class="footer__top">
      <div class="footer__statement">
        <p class="footer__claim">
          Diese Website ist kein Praxisauftritt.<br />
          Sie ist eine persönliche Stellungnahme.
        </p>
      </div>
      <nav class="footer__nav" aria-label="Footer-Navigation">
        <div class="footer__nav-col">
          <span class="footer__nav-label">Inhalt</span>
          <ul role="list">
            <li><a href="/hintergrund">Hintergrund &amp; Fakten</a></li>
            <li><a href="/standpunkt">Mein Standpunkt</a></li>
            <li><a href="/quellen">Quellen &amp; Belege</a></li>
            <li><a href="/mitmachen">Mitmachen &amp; Teilen</a></li>
          </ul>
        </div>
        <div class="footer__nav-col">
          <span class="footer__nav-label">Kontakt &amp; Recht</span>
          <ul role="list">
            <li><a href="/kontakt">Kontakt</a></li>
            <li><a href="/impressum">Impressum</a></li>
            <li><a href="/datenschutz">Datenschutz</a></li>
          </ul>
        </div>
      </nav>
    </div>

    <div class="footer__bottom">
      <p class="footer__copy">
        &copy; {year} Dr. Roman Kubetschek · Neubrandenburg
      </p>
      <p class="footer__legal">
        Persönliche Meinungsäußerungen sind als solche kenntlich gemacht.
        Fakten sind mit Quellenangaben belegt.
      </p>
    </div>

  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-black);
    color: rgba(255,255,255,0.45);
    margin-top: var(--space-24);
    padding-block: var(--space-12);
  }

  .footer__body { display: flex; flex-direction: column; gap: var(--space-12); }

  .footer__top {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  @media (min-width: 768px) {
    .footer__top { grid-template-columns: 1fr auto; align-items: start; gap: var(--space-16); }
  }

  .footer__claim {
    font-family: var(--font-display);
    font-size: clamp(var(--text-xl), 3vw, var(--text-3xl));
    font-weight: 700;
    font-style: italic;
    color: rgba(255,255,255,0.75);
    line-height: 1.3;
    max-width: none;
    margin: 0;
  }

  .footer__nav {
    display: flex;
    gap: var(--space-8);
    flex-wrap: wrap;
  }

  .footer__nav-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer__nav-label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.25);
    margin-bottom: var(--space-1);
  }

  .footer__nav ul { list-style: none; display: flex; flex-direction: column; gap: 6px; }
  .footer__nav a {
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.45);
    text-decoration: none;
    transition: color var(--transition-base);
  }
  .footer__nav a:hover { color: var(--color-white); }

  .footer__bottom {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .footer__copy {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    margin: 0; max-width: none;
  }

  .footer__legal {
    font-size: var(--text-xs);
    color: rgba(255,255,255,0.2);
    margin: 0; max-width: none;
  }
</style>
