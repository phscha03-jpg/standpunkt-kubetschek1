</Layout>

<style>
  .page-header-text {
    background-color: var(--color-black);
    padding-block: var(--space-12);
  }
  .page-header-text h1 { color: var(--color-white); margin-top: var(--space-3); }
  .page-header-text .gold-rule { margin-bottom: var(--space-3); }

  .legal-content {
    max-width: 760px;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .legal-content h2 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-3);
  }

  .legal-content h3 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-2);
    color: var(--color-green);
  }

  .legal-content p, .legal-content address { font-size: var(--text-sm); max-width: none; margin: 0; line-height: 1.7; }

  address { font-style: normal; }

  .legal-dl {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: var(--space-2) var(--space-4);
  }

  dt {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-muted);
    padding-top: 2px;
  }

  dd {
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.6;
  }

  .todo-banner {
    background-color: rgba(184, 146, 46, 0.1);
    border: 1px solid var(--color-gold);
    border-left: 4px solid var(--color-gold);
    padding: var(--space-4);
  }

  .todo-banner strong {
    display: block;
    font-size: var(--text-base);
    color: var(--color-gold);
    margin-bottom: var(--space-2);
  }

  .todo-banner p { font-size: var(--text-sm); color: var(--color-text-muted); max-width: none; margin: 0; }

  .legal-checklist {
    background-color: var(--color-white);
    border: 1px solid var(--color-rule);
    padding: var(--space-4);
  }

  .legal-checklist h2 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-3);
  }

  .legal-checklist ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .legal-checklist li {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-family: monospace;
  }

  code {
    background-color: var(--color-rule);
    padding: 1px 4px;
    border-radius: 2px;
    font-size: 0.85em;
  }
</style>
